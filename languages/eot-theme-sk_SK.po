msgstr "Balík 4 sedenia"

msgid "Пишу стихи, картины, песни. Интересуюсь физиологией, суплементологией, массажем, биоэнергетикой. Практикую авторские сессии «Энергосканер»."
msgstr "Píšem básne, maľujem obrazy a tvorím piesne. Zaujímam sa o fyziológiu, suplementológiu, masáž a bioenergetiku. Praktizujem autorské sedenia „Energoscanner“."

msgid "Подберите формат, который подходит вашему запросу."
msgstr "Vyberte si vhodný formát."

msgid "Подтверждение обучения и повышения квалификации."
msgstr "Potvrdenie vzdelania."

msgid "Полимодальный подход"
msgstr "Polymodálny prístup"

msgid "Последовательная поддержка и сопровождение."
msgstr "Podpora a sprevádzanie."

msgid "Предыдущая"
msgstr "Predchádzajúci"

msgid "Преодоление внутренних барьеров, обретение смелости заявлять о себе и своих талантах."
msgstr "Prekonanie vnútorných bariér, získanie odvahy prejaviť sa a prezentovať svoje talenty."

msgid "Причиной телесного дискомфорта, боли, недомогания или хронических заболеваний часто становятся подавленные чувства и нерешенные конфликты. Эмоционально-образная терапия (ЭОТ) помогает выявить и проработать эти скрытые причины, позволяя человеку осознать свои эмоции и снять внутренние блоки. Благодаря работе с образами и чувствами, ЭОТ способствует восстановлению гармонии между психикой и телом, что проявляется улучшением самочувствия и избавлением от психосоматических симптомов."
msgstr "Príčinou telesného diskomfortu, bolesti, nevoľnosti alebo chronických ochorení bývajú často potlačené pocity a nevyriešené konflikty. EOT pomáha odhaliť a spracovať tieto skryté príčiny, aby človek lepšie porozumel svojim emóciám a uvoľnil vnútorné bloky. Vďaka práci s obrazmi a pocitmi EOT podporuje obnovu harmónie medzi psychikou a telom, čo sa prejavuje zlepšením pohody a ústupom psychosomatických symptómov."

msgid "Провокативное, психологическое консультирование и коучинг."
msgstr "Provokatívne psychologické poradenstvo a koučing."

msgid "Психоблоки"
msgstr "Psychické bloky"

msgid "Психолог ЭОТ онлайн"
msgstr "EOT psycholog online"

msgid "Психологическая поддержка методом эмоционально-образной терапии для русскоязычных за границей."
msgstr "Psychologická podpora EOT pre rusky hovoriacich v zahraničí."

msgid "Психологическая помощь не является медицинской услугой."
msgstr "Psychologická pomoc nie je zdravotná služba."

msgid "Психологическое консультирование."
msgstr "Psychologické poradenstvo."

msgid "Путь в профессию"
msgstr "Moja cesta v profesii"

msgid "Работа с причинами нарушения сна, нормализация режима и обретение ночного спокойствия."
msgstr "Práca s príčinami porúch spánku, normalizácia režimu a získanie nočného pokoja."

msgid "Работала на заводе экономистом и комсоргом. С 1992 года стала предпринимателем: работала директором магазина и коммерческим директором кирпичного завода, стала автором рецептур, изобретений, промышленных образцов и рационализаторских предложений в сфере кирпичного производства."
msgstr "Pracovala som v závode ako ekonómka a komsorg. Od roku 1992 som podnikateľka: pôsobila som ako riaditeľka predajne a obchodná riaditeľka tehelne, som autorkou receptúr výrobkov, vynálezov, priemyselných vzorov a zlepšovacích návrhov v oblasti tehlovej výroby."

msgid "Работаю с тревогой, самооценкой, страхом проявленности, бессонницей, фобиями, психоблоками, эмоциональными травмами и другими запросами."
msgstr "Práca s úzkosťou, sebaúctou, strachom z prejavu, nespavosťou, fóbiami, psychoblokmi, emocionálnymi traumami a ďalšími témami."

msgid "Разбор одного запроса с опорой на ЭОТ."
msgstr "Práca s jedným témou."

msgid "Регрессивный гипноз."
msgstr "Regresívnu hypnózu."

msgid "Русскоговорящий психолог, коуч за рубежом"
msgstr "Rusky hovoriaci psychológ a kouč v zahraničí"

msgid "С какими запросами можно прийти"
msgstr "S čím môžete prísť"

msgid "Самооценка"
msgstr "Sebahodnotenie"

msgid "Светлана Бугела — гипнокоучинг, самогипноз."
msgstr "Svetlana Bugela — hypnokoučing, autohypnóza."

msgid "Семинар возрождения внутренней силы"
msgstr "Seminár o obnovení vnútornej sily"

msgid "Сертификаты"
msgstr "Certifikáty"

msgid "Сессия"
msgstr "Sedenie"

msgid "Следующая"
